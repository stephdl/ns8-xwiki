# Recreate state/initdb.d/init.sql from the module after 40restore_database
# cleaned it up. The file is derived from imageroot/sql/init.sql so it is
# never stored in the Restic backup.

import os
import shutil

state_dir = os.environ['AGENT_STATE_DIR']
install_dir = os.environ['AGENT_INSTALL_DIR']

initdb_dir = os.path.join(state_dir, 'initdb.d')
os.makedirs(initdb_dir, exist_ok=True)
shutil.copy2(os.path.join(install_dir, 'sql', 'init.sql'),
             os.path.join(initdb_dir, 'init.sql'))
