import sys
import json
import agent

request = json.load(sys.stdin)

original_environment = request['environment']

# Restore non-secret environment variables (from Redis/state/environment).
# Passwords are NOT listed here: state/passwords.env is restored automatically
# by Restic (via etc/state-include.conf) and must never transit through Redis.
for evar in [
        "TRAEFIK_HOST",
        "JAVA_HEAP_MB",
        "JAVA_OPTS",
    ]:
    if evar in original_environment:
        agent.set_env(evar, original_environment[evar])

agent.dump_env()
