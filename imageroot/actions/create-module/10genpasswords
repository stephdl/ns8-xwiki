# Generate random DB passwords and write to state/passwords.env.
# Passwords MUST NOT be stored in Redis (agent.set_env) since Redis is
# readable by all modules on the node. The file is:
#   - loaded by systemd units via EnvironmentFile=-%S/state/passwords.env
#   - passed to containers via podman --env-file=%S/state/passwords.env
#   - backed up by Restic (listed in etc/state-include.conf)

import sys
import os
import secrets

passwords_file = os.path.join(os.environ['AGENT_STATE_DIR'], 'passwords.env')

# Idempotent: only generate on first install
if not os.path.exists(passwords_file):
    db_password = secrets.token_urlsafe(16)
    db_root_password = secrets.token_urlsafe(16)
    xwiki_superadmin_password = secrets.token_urlsafe(16)

    tmpfile = passwords_file + '.tmp'
    with open(tmpfile, 'w') as fp:
        print(f"DB_PASSWORD={db_password}", file=fp)
        print(f"DB_ROOT_PASSWORD={db_root_password}", file=fp)
        print(f"XWIKI_SUPERADMIN_PASSWORD={xwiki_superadmin_password}", file=fp)
    os.replace(tmpfile, passwords_file)
    os.chmod(passwords_file, 0o600)
