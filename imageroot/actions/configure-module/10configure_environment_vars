import json
import sys
import agent

data = json.load(sys.stdin)

host = data["host"]
agent.set_env("TRAEFIK_HOST", host)

# JVM heap size in MB — controls XWiki Tomcat memory allocation
java_heap_mb = int(data.get("java_heap_mb", 1024))
agent.set_env("JAVA_HEAP_MB", java_heap_mb)
agent.set_env("JAVA_OPTS", f"-Xmx{java_heap_mb}m -Xms{java_heap_mb}m")
