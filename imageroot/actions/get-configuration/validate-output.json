{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Get xwiki configuration output",
    "$id": "http://nethserver.org/json-schema/task/output/xwiki/get-configuration",
    "description": "Get xwiki configuration output",
    "type": "object",
    "required": ["host", "lets_encrypt", "java_heap_mb"],
    "properties": {
        "host": {
            "type": "string"
        },
        "lets_encrypt": {
            "type": "boolean"
        },
        "java_heap_mb": {
            "type": "integer",
            "minimum": 256,
            "maximum": 8192
        }
    }
}
