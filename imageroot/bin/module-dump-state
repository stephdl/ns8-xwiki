# SPDX-License-Identifier: GPL-3.0-or-later
#

set -e

if ! systemctl --user -q is-active xwiki.service; then
    exit 0
fi

declare -A passwords
while IFS='=' read -r key value; do
    passwords[$key]=$value
done < "${AGENT_STATE_DIR}/passwords.env"

DB_ROOT_PASSWORD=${passwords[DB_ROOT_PASSWORD]}

if [ -z "${DB_ROOT_PASSWORD}" ]; then
    echo "Missing DB_ROOT_PASSWORD in ${AGENT_STATE_DIR}/passwords.env" >&2
    exit 1
fi

podman exec mariadb-app mariadb-dump \
        -uroot -p"${DB_ROOT_PASSWORD}" \
        --databases xwiki \
        --default-character-set=utf8mb4 \
        --skip-dump-date \
        --ignore-table=mysql.event \
        --single-transaction \
        --quick \
        --add-drop-table  > xwiki.sql
